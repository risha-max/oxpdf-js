{
  "name": "oxpdf",
  "version": "0.1.2",
  "description": "TypeScript/JavaScript SDK for the 0xPdf PDF-to-JSON API",
  "keywords": [
    "pdf",
    "ocr",
    "parsing",
    "json",
    "api",
    "document",
    "extraction"
  ],
  "license": "MIT",
  "author": "0xPdf",
  "repository": {
    "type": "git",
    "url": "https://github.com/risha-max/oxpdf-js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
